{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:80} {
	log {
		format json
	}

	respond /health 200

	header {
		X-Content-Type-Options "nosniff"
		-Server
	}

	root * /app/dist

	encode {
		gzip
		zstd
	}

	try_files {path} {path}.html {path}/index.html

	file_server {
		hide .git
		hide .env*
	}

	handle_errors {
		@404 {
			expression {err.status_code} == 404
		}
		rewrite @404 /404.html
		file_server
	}
}
