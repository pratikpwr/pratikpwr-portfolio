---
import { workItems } from '../data/portfolio';
---

<section id="work" class="work wrap" aria-labelledby="work-h">
  <div class="work-head">
    <h2 id="work-h">Selected work</h2>
    <a class="u-link" href="https://github.com/pratikpwr" target="_blank" rel="noopener noreferrer">GitHub profile</a>
  </div>
  <div class="index">
    {workItems.map((item, i) => (
      <a
        class="row"
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="n">{String(i + 1).padStart(2, '0')}</span>
        <div class="row-main">
          <h3>{item.title}</h3>
          <p class="desc">{item.description}</p>
          {item.stack && <p class="stack">{item.stack}</p>}
        </div>
        <span class="org">{item.org}</span>
        <span class="go">{item.cta}</span>
      </a>
    ))}
  </div>
</section>
