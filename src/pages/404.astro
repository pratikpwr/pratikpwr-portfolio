---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---

<Base
  title="Page not found — Pratik Pawar"
  description="The page you requested could not be found."
  noindex
>
  <Nav />
  <main id="main" class="not-found wrap">
    <p class="eyebrow">404</p>
    <h1>This page didn’t ship.</h1>
    <p class="nf-lead">
      The URL may have moved, or it never existed. Head back home and keep scrolling.
    </p>
    <a class="u-link" href="/">Back to portfolio</a>
  </main>
</Base>

<style>
  .not-found {
    min-height: 70svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 18px;
    padding-block: clamp(80px, 14vh, 140px);
  }
  .not-found h1 {
    font-weight: 500;
    letter-spacing: -0.03em;
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    line-height: 1.05;
  }
  .nf-lead {
    max-width: 34em;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    color: var(--grey);
    margin-bottom: 12px;
  }
</style>
